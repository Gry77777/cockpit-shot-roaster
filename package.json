{
  "name": "cockpit-shot-roaster",
  "private": true,
  "version": "0.1.0",
  "description": "一个只读联动 Codex 账号的桌面截图吐槽机。",
  "author": "Codex",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "electron dist-electron/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:win": "npm run build && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.codex.cockpitshotroaster",
    "productName": "截图吐槽机",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "shot-roaster-setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "截图吐槽机",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.2",
    "png-to-ico": "^3.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "openai": "^6.34.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
